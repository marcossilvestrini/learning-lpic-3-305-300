{
    "builders": [
        {
            "type": "lxd",
            "image": "images:debian/13",
            "name": "lxd-example",
            "init_sleep": "10"
        }
    ],
    "provisioners": [
        {
            "type": "shell",
            "inline": 
	    [		
        "dhclient",
		"rm /etc/resolv.conf",
		"echo \"nameserver 8.8.8.8\" > /etc/resolv.conf",
		"cat /etc/resolv.conf",
		"until apt-get update -y; do echo 'Waiting for network...' && sleep 5; done",
		"apt-get install apache2 -y"
	    ]
        },
        {
            "type": "file",
            "source": "index.html",
            "destination": "/var/www/html/"
        },
        {
            "type": "shell",
            "script": "deploy.sh"
        }
    ],
   "post-processors": [
    {
      "type": "shell-local",
      "inline": [
         "lxc image export packer-lxd-example lxd-example",
         "cp lxd-example.tar.gz /tmp/"
      ]
    }
  ]
}

